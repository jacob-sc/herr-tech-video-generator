ANTHROPIC_API_KEY=

# OpenAI (Whisper Transkription) — https://platform.openai.com → API Keys
OPENAI_API_KEY=

# Google AI (Gemini / Nano Banana) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Fal.ai (Veo 3 Lite Videos + Kling als Fallback) — https://fal.ai/dashboard/keys
FAL_API_KEY=
